# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# 원본/소스 참고 자료 (public/ 안의 최종본과 중복, 인물 사진 포함 — 저장소에 올리지 않음)
/피팅 모델/

# 실제 인물 사진 (피팅 베이스 모델) — 공개 저장소 노출 방지, 배포 시 별도 방식으로 주입 필요
/public/models/

# typescript
*.tsbuildinfo
next-env.d.ts
